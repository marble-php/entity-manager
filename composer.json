{
    "name": "marble/entity-manager",
    "description": "An ORM-less entity lifecycle manager for PHP.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/marble-php/entity-manager",
    "authors": [
        {
            "name": "Mark van den Berg",
            "email": "mjpvandenberg@gmail.com"
        }
    ],
    "keywords": [
        "entity",
        "entity manager",
        "unit of work",
        "repository",
        "orm"
    ],
    "require": {
        "php": "^8.2",
        "psr/event-dispatcher": "^1.0",
        "sebastian/comparator": "^4.0|^5.0",
        "symfony/var-exporter": "^7.4|^8.0"
    },
    "require-dev": {
        "dg/bypass-finals": "^1.9",
        "mockery/mockery": "^1.6.12",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10|^11|^12|^13",
        "symfony/uid": "^7.4|^8.0"
    },
    "suggest": {
        "symfony/uid": "If you want to use the provided UUID and ULID implementation of the Identifier interface."
    },
    "autoload": {
        "psr-4": {
            "Marble\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marble\\Tests\\": "tests"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        },
        "sort-packages": true
    }
}
